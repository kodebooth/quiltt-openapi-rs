{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.22.0",
    "generators": {
      "quiltt-openapi-rs": {
        "generatorName": "rust",
        "inputSpec": "https://api.quiltt.io/latest/rest.yaml",
        "additionalProperties": {
          "library": "reqwest-trait",
          "mockall": true,
          "packageName": "quiltt-openapi-rs",
          "packageVersion": "2026.4.1+0",
          "topLevelApiClient": true
        }
      }
    }
  }
}
